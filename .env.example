# copy this file to .env.dev or .env.test and fill in values.
# dev and test have fallback defaults in settings.py (.env files are optional for those environments).
# URI format: postgresql+psycopg2://username:pass@host:port/dbname

FLASK_APP_ENV=prod
PROD_DATABASE_URI=postgresql+psycopg2://DB_USERNAME:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME
SECRET_KEY=secret-key-goes-here
JWT_SECRET_KEY=jwt-key-goes-here
# FRONTEND_BASE_URL=https://webiste.com
WEBSITE_DOMAIN=http://localhost:3000
BREVO_API_KEY=your-brevo-api-key-here
BREVO_SENDER_NAME=name
BREVO_SENDER_EMAIL=hello@brevo.com

