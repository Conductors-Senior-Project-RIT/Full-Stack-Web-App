# Copy to .env.dev or .env.test and fill in values
# ENV: dev or test
# URI format: postgresql+psycopg2://username:pass@localhost:5432/dbname
# note: only confident that test env is setup, unsure if it's worth to even setup dev env lol
# note2: not sure how prod setup would look like atm
# note3: .env.test and .env.dev are not necessary files; testing config has default values it'll fall back to

FLASK_APP_ENV=env
ENV_DATABASE_URI=postgresql+psycopg2://DB_USERNAME:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME
SECRET_KEY=secret-key-goes-here
JWT_SECRET_KEY=jwt-key-goes-here

